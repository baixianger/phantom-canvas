{
  "name": "phantom-canvas",
  "version": "2.0.0",
  "description": "Your Gemini web app as a service — turn the free Gemini web interface into a programmable HTTP API for image and video generation via Chrome CDP.",
  "module": "index.ts",
  "type": "module",
  "keywords": [
    "agent-skills",
    "mcp-server",
    "gemini",
    "image-generation",
    "video-generation",
    "browser-automation",
    "pixel-art",
    "game-assets",
    "ai-agent",
    "phantom-canvas",
    "chrome-cdp"
  ],
  "author": "baixianger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baixianger/phantom-canvas.git"
  },
  "bin": {
    "phantom-canvas": "cli.js"
  },
  "files": [
    "cli.js",
    "dist/",
    "lib/",
    "README.md",
    "examples.md",
    "logo.png",
    "diagram.png"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node --external playwright-core --external ws --external @hono/node-server --external hono",
    "generate": "node --import tsx index.ts generate",
    "serve": "node --import tsx index.ts serve",
    "dev": "node --import tsx index.ts serve --headed"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.9",
    "playwright-core": "^1.59.1",
    "ws": "^8.20.0"
  }
}
