{
  "name": "phantom-canvas",
  "version": "0.2.0",
  "description": "Your Gemini web app as a service — turn the free Gemini web interface into a programmable HTTP API for image and video generation",
  "module": "index.ts",
  "type": "module",
  "keywords": ["gemini", "ai", "image-generation", "video-generation", "browser-automation", "camoufox", "pixel-art", "sprite", "game-assets"],
  "author": "baixianger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baixianger/phantom-canvas.git"
  },
  "bin": {
    "phantom-canvas": "cli.ts"
  },
  "files": [
    "index.ts",
    "cli.ts",
    "lib/",
    "README.md",
    "examples.md"
  ],
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun run index.ts --headed",
    "login": "bun run index.ts login",
    "setup": "bunx camoufox-js fetch",
    "postinstall": "bunx camoufox-js fetch"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "camoufox-js": "^0.9.3",
    "hono": "^4.12.9"
  }
}
